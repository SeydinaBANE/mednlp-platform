# ── LLM via OpenRouter ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL_HEAVY=anthropic/claude-3.5-sonnet
OPENROUTER_MODEL_LIGHT=anthropic/claude-3-haiku
APP_URL=http://localhost:8000

# ── Base de données ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mednlp
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/mednlp

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=mednlp-dev
GCP_REGION=us-central1
PUBSUB_TOPIC_NOTES=notes.incoming
PUBSUB_SUBSCRIPTION_NOTES=notes.processor
PUBSUB_TOPIC_DLQ=notes.dlq
GCS_BUCKET_RAW=mednlp-raw-notes-dev
GCS_BUCKET_PROCESSED=mednlp-processed-notes-dev
GCS_BUCKET_ARTIFACTS=mednlp-model-artifacts-dev
PUBSUB_EMULATOR_HOST=localhost:8085

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=100

# ── Alerting (optionnel en dev) ───────────────────────────────────────────────
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=
